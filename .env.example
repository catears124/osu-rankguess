# osu! OAuth client-credentials app. Required for current ranks and cron replay sourcing.
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# Strongly recommended. Without verification, o!rdr rate-limits render submissions.
ORDR_API_KEY=
ORDR_SKIN=whitecatCK1.0
ORDR_RESOLUTION=960x540

# Required for signed replay feature tokens.
CACHE_SIGNING_SECRET=

# Vercel cron sends this as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Vercel's Supabase integration injects POSTGRES_URL automatically.
# Do not add a fake DATABASE_URL. For local development only, either variable works.
# POSTGRES_URL=postgresql://...
# DATABASE_URL=postgresql://...

# Used to turn predicted percentile into predicted global rank.
OSU_RANK_POPULATION=5500000

# Keep daily selection and public IDs stable across deploys.
DAILY_CHALLENGE_SALT=
GALLERY_ID_SALT=

# The cron stops adding robot-found entries once this many challenge-eligible rows exist.
GALLERY_SEED_TARGET=12

# Keep below the Vercel function max duration. Typical renders finish well before this.
SEED_RENDER_TIMEOUT_SECONDS=160

REPLAY_CACHE_TTL_SECONDS=1800

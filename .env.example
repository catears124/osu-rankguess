# Required for o!rdr metadata and current osu! global ranks.
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# Recommended for o!rdr throughput.
ORDR_API_KEY=
ORDR_SKIN=whitecatCK1.0
ORDR_RESOLUTION=960x540

# Required for signed replay feature tokens.
CACHE_SIGNING_SECRET=

# Neon/Supabase/other serverless Postgres connection string.
# The app creates its tables automatically on first use.
DATABASE_URL=

# Used to turn predicted percentile into predicted global rank.
OSU_RANK_POPULATION=5500000

# Keep daily selection and public IDs stable across deploys.
DAILY_CHALLENGE_SALT=
GALLERY_ID_SALT=

REPLAY_CACHE_TTL_SECONDS=1800

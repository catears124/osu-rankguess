# Required. Generate a long random value, e.g.:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
CACHE_SIGNING_SECRET=

# Optional but strongly recommended. Without a verified o!rdr key, public
# requests are subject to o!rdr's unauthenticated render limits.
ORDR_API_KEY=

# Optional o!rdr render settings.
ORDR_SKIN=whitecatCK1.0
ORDR_RESOLUTION=960x540

# Optional: return an approximate numeric rank in addition to percentile.
# OSU_RANK_POPULATION=3000000

# Optional: how long a signed replay feature token remains valid.
# REPLAY_CACHE_TTL_SECONDS=1800
